.claude/

# Vendored FFmpeg source tree (cloned via git, not a submodule).
# NOTE: case-insensitive matching on macOS means `ffmpeg/` also matches
# `Rivulet/Services/Plex/Playback/FFmpeg/`, which is our tracked Swift
# integration directory. Re-include it explicitly so new Swift files
# added there are not silently ignored.
ffmpeg/
!Rivulet/Services/Plex/Playback/FFmpeg/
!Rivulet/Services/Plex/Playback/FFmpeg/**

# Secrets (do not commit)
Rivulet/Config/Secrets.swift

# Internal developer docs — kept locally, not in the repo.
Docs/

# Playwright MCP session scratch (browser snapshots, traces, etc.)
.playwright-mcp/

# Rolling worklog + lessons — kept locally, not in the repo.
tasks/
.superpowers/
SENTRY_FIXES/
SENTRY_PATCHES/

# Personal test content map (rating keys are user-specific)
Docs/TEST_CONTENT_RATING_KEYS.md

# Local perf-test output
perf_results.csv
perf_results_device.csv
